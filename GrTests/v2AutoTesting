//a run to target position drive mode with otos, includes proportional control and position correction
//attempting to test for adding angles within the moveToTargetPosition
//included everything about h data coming from the OTOS, the heading angle
//different from the old code
//under testing
private void moveToTargetUsingOTOS(double targetX, double targetY, double targetH) {
    SparkFunOTOS.Pose2D currentPosition = myOtos.getPosition();

    while (opModeIsActive() && (Math.abs(currentPosition.x - targetX) > 0.1 || Math.abs(currentPosition.y - targetY) > 0.1 || Math.abs(currentPosition.h - targetH) > 0.1)) {
        double xPower = (targetX - currentPosition.x) * 0.2; // Proportional control
        double yPower = (targetY - currentPosition.y) * 0.2;
        double hPower = (targetH - currentPosition.h) * 0.2; 
        
       double hRad = Math.toRadians(angleWrap(currentPosition.h));

        double xRotate = (xPower* Math.cos(hRad)) - (yPower * (Math.sin(hRad)));
        double yRotate = (xPower* Math.sin(hRad)) + (yPower * (Math.cos(hRad)));

         //Clamps the values between -1 and 1, see utility method below using Math.max and Math.min
        xRotate = clamp(xPower, -1, 1);
        yRotate = clamp(yPower, -1, 1);
        hPower = clamp(hPower, -1, 1);

        // Apply motor power (example, adjust based on your drivetrain)
        driveMotors(yRotate, xRotate, hPower);

        currentPosition = myOtos.getPosition();
        telemetry.addData("Current OTOS X", currentPosition.x);
        telemetry.addData("Current OTOS Y", currentPosition.y);
        telemetry.addData("Current OTOS H", currentPosition.h);
        telemetry.update();
    }

    stopMotors();
}
//a run to position for angles while in same spot
private void moveToTargetAngleUsingOTOS(double targetH) {
    SparkFunOTOS.Pose2D currentPosition = myOtos.getPosition();

    if (opModeIsActive() && (Math.abs(currentPosition.h - targetH) > 0.1)) {
        // Proportional control
        double hPower = (targetH - currentPosition.h) * 0.2; 

         //Clamps the values between -1 and 1, see utility method below using Math.max and Math.min
        hPower = clamp(hPower, -1, 1);

        // Apply motor power (example, adjust based on your drivetrain)
        //zeros for x and y due to stable position
        driveMotors(0, 0, hPower);

        currentPosition = myOtos.getPosition();
        telemetry.addData("Current OTOS X", currentPosition.x);
        telemetry.addData("Current OTOS Y", currentPosition.y);
        telemetry.addData("Current OTOS H", currentPosition.h);
        telemetry.update();
    }

    stopMotors();
}
//setting the power of drive motors, through the calculation done in the run to target position drive mode
//also added in rotatePowers
private void driveMotors(double forwardPower, double strafePower, double rotatePower) {
    // Example drivetrain power logic
    double frontLeft = forwardPower + strafePower + rotatePower;
    double frontRight = forwardPower - strafePower - rotatePower;
    double backLeft = forwardPower - strafePower + rotatePower;
    double backRight = forwardPower + strafePower - rotatePower;

    m1.setPower(backLeft);
    m2.setPower(frontLeft);
    m3.setPower(frontRight);
    m4.setPower(backRight);
}
//stopping all motors, setting all to 0
private void stopMotors() {
    m1.setPower(0);
    m2.setPower(0);
    m3.setPower(0);
    m4.setPower(0);
}
