//being able to clamp the values into the desired minimum and maximum, so it doesn't exceed limit
private double clamp(double value, double min, double max) {
        return Math.max(min, Math.min(max, value));
}  
//wrapping angle, so it doesn't exceed the maximum limit of the radian 2pi
private double anglewrap(double radians){
    while(radians > Math.Pi){
        radians-=2*Math.Pi;
    }
    while(radians < -Math.Pi){
            radians+=2*Math.Pi;
    }
return radians;
}
